-- Silent Aim (__index 후킹 삭제: 안티치트 감지됨. 대신 StartShooting에서 카메라 CFrame을 순간 스냅하여 조준 우회)
if GunItem then
    local oldStartShooting = GunItem.StartShooting
    GunItem.StartShooting = function(controller, ...)
        local results = {nil}
        local originalCamCFrame = nil
        local silentAimActive = Toggles.SilentAim and Toggles.SilentAim.Value and CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("Head")
        
        if silentAimActive then
            originalCamCFrame = Cam.CFrame
            Cam.CFrame = CFrame.new(originalCamCFrame.Position, CurrentTarget.Character.Head.Position)
        end
        
        local success, err = pcall(function()
            results = {oldStartShooting(controller, ...)}
        end)
        
        if silentAimActive and originalCamCFrame then
            Cam.CFrame = originalCamCFrame
        end
        
        if not success then warn("Shooting Error: " .. tostring(err)) end
        
        local clientFighter = controller.ClientFighter 
        if clientFighter and clientFighter.IsLocalPlayer then
            -- 1. 트레이서 로직
            if Toggles.AccuracyTracer and Toggles.AccuracyTracer.Value or (Toggles.LineBeamTrail and Toggles.LineBeamTrail.Value) then
                local startPos = Cam.CFrame.Position
                local viewModels = Workspace:FindFirstChild("ViewModels")
                if viewModels then
                    for _, m in ipairs(viewModels:GetChildren()) do
                        if m:IsA("Model") then
                            local sp = m.Name:find(" - ", 1, true)
                            if sp and m.Name:sub(1, sp - 1) == LP.Name then
                                local muzzle = m:FindFirstChild("Muzzle", true) or m:FindFirstChild("Barrel", true) or m:FindFirstChild("FirePoint", true)
                                if muzzle then startPos = muzzle.Position end
                                break
                            end
                        end
                    end
                end
                local endPos = CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("Head") and CurrentTarget.Character.Head.Position or (startPos + Cam.CFrame.LookVector * 1000)
                
                if Toggles.AccuracyTracer and Toggles.AccuracyTracer.Value then
                    local p = Instance.new("Part")
                    p.Anchored = true; p.CanCollide = false; p.CanQuery = false; p.CanTouch = false
                    p.Transparency = 0; p.Material = Enum.Material.Neon; p.Color = Color3.fromRGB(255, 255, 100)
                    p.Size = Vector3.new(0.1, 0.1, (startPos - endPos).Magnitude)
                    p.CFrame = CFrame.new(startPos, endPos) * CFrame.new(0, 0, -p.Size.Z / 2)
                    p.Parent = Workspace
                    game:GetService("Debris"):AddItem(p, 0.5)
                end
                if Toggles.LineBeamTrail and Toggles.LineBeamTrail.Value then
                    local a1 = Instance.new("Attachment", Workspace.Terrain)
                    local a2 = Instance.new("Attachment", Workspace.Terrain)
                    a1.WorldPosition = startPos; a2.WorldPosition = endPos
                    local beam = Instance.new("Beam")
                    beam.Attachment0 = a1; beam.Attachment1 = a2
                    beam.Width0 = Options.LineBeamWidth.Value; beam.Width1 = Options.LineBeamWidth.Value
                    beam.Color = ColorSequence.new(Options.LineBeamColor.Value)
                    beam.LightEmission = Options.LineBeamLightEmission.Value
                    beam.TextureSpeed = Options.LineBeamTextureSpeed.Value
                    beam.TextureLength = Options.LineBeamTextureLength.Value
                    beam.Texture = "rbxassetid://2436603644" 
                    beam.Parent = a1
                    local duration = Options.LineBeamDuration.Value
                    if Toggles.LineBeamFadeOut.Value then
                        local speed = Options.LineBeamFadeSpeed.Value
                        local tweenInfo = TweenInfo.new(duration / speed, Enum.EasingStyle.Linear)
                        game:GetService("TweenService"):Create(beam, tweenInfo, {Transparency = NumberSequence.new(1)}):Play()
                        game:GetService("Debris"):AddItem(a1, duration / speed)
                        game:GetService("Debris"):AddItem(a2, duration / speed)
                    else
                        game:GetService("Debris"):AddItem(a1, duration)
                        game:GetService("Debris"):AddItem(a2, duration)
                    end
                end
            end

            -- 2. 월뱅 로직 (GetCameraData 조작 없이 Desync만 수행)
            if Toggles.Wallbang and Toggles.Wallbang.Value then
                local targetPlayer = CurrentTarget
                if targetPlayer and targetPlayer.Character then
                    if env.DesyncController.currentTarget ~= targetPlayer then 
                        env.DesyncController:Start(targetPlayer)
                        task.wait(0.1)
                    end 
                    task.delay(0.15, function() env.DesyncController:Stop() end)
                end
            end
        end
        return unpack(results)
    end
end

env.DesyncController = {} 
do 
    function DesyncController:init()
        self.active = false 
        self.connection = nil 
        self.currentTarget = nil 
    end 
    function DesyncController:Start(target)
        self:Stop() 
        self.active = true 
        self.connection = RunService.Heartbeat:Connect(function() 
            if not self.active then return end 
            local rootPart = LP.Character and LP.Character:FindFirstChild('HumanoidRootPart')
            if not rootPart then return end 
            local targetRoot = target and target.Character and target.Character:FindFirstChild('HumanoidRootPart')
            if not targetRoot then self:Stop() return end 
            self.currentTarget = target
            local desyncCFrame = targetRoot.CFrame * CFrame.new(0, 7, -2)
            local backupCFrame = rootPart.CFrame 
            local backupVelocity = rootPart.Velocity 
            local backupRotVelocity = rootPart.RotVelocity 
            rootPart.CFrame = desyncCFrame 
            RunService:BindToRenderStep('desync_fallback', 101, function() 
                rootPart.CFrame = backupCFrame 
                rootPart.Velocity = backupVelocity 
                rootPart.RotVelocity = backupRotVelocity 
                RunService:UnbindFromRenderStep('desync_fallback')
            end)
        end) 
    end 
    function DesyncController:Stop()
        self.active = false 
        self.currentTarget = nil 
        if self.connection then self.connection:Disconnect(); self.connection = nil end 
    end 
    DesyncController:init()
end 

